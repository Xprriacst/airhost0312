# Airtable Configuration
VITE_AIRTABLE_API_KEY=your_airtable_api_key_here
VITE_AIRTABLE_BASE_ID=your_airtable_base_id_here

# OpenAI Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# WhatsApp Configuration
VITE_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
VITE_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
VITE_WHATSAPP_VERIFY_TOKEN=your_custom_verification_token

# Note: When deploying to Netlify, set these environment variables
# in the Netlify dashboard without the VITE_ prefix:
# AIRTABLE_API_KEY
# AIRTABLE_BASE_ID
# OPENAI_API_KEY
# WHATSAPP_PHONE_NUMBER_ID
# WHATSAPP_ACCESS_TOKEN
# WHATSAPP_VERIFY_TOKEN
